# Azure Developer CLI configuration for Aerulias AI
# 
# Use this file to set environment-specific values for Azure deployment
# Copy to .env.local to override for your environment

# Azure subscription and resource details
AZURE_ENV_NAME=dev
AZURE_RESOURCE_TOKEN=

# Application settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://your-app-name.azurewebsites.net
OPENROUTER_APP_NAME=aerulias_ai

# Infrastructure settings
AZURE_LOCATION=eastus
ENABLE_APP_INSIGHTS=true
