# Aerulias AI - Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================

# Application environment (development, staging, production)
ENV=development

# Enable debug mode (only for development)
DEBUG=false

# ============================================================================
# OPENROUTER API CONFIGURATION
# ============================================================================

# Your OpenRouter API key from https://openrouter.ai
# Required for all operations
OPENROUTER_API_KEY=your_api_key_here

# OpenRouter API base URL (usually no need to change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use for generation and refinement
# Examples: openai/gpt-4o, openai/gpt-4-turbo, anthropic/claude-3-sonnet
OPENROUTER_MODEL=openai/gpt-4o-mini

# Site URL for OpenRouter usage tracking
OPENROUTER_SITE_URL=http://localhost

# Application name for OpenRouter tracking
OPENROUTER_APP_NAME=aerulias_ai

# ============================================================================
# MODEL PARAMETERS - Temperature Controls Creativity
# ============================================================================

# Generator temperature (creativity) - 0.0 = deterministic, 1.0 = creative
# 0.7 provides good balance between creativity and consistency
GENERATOR_TEMPERATURE=0.7

# Evaluator temperature (consistency) - use low for consistent scoring
# 0.2 ensures consistent evaluation results
EVALUATOR_TEMPERATURE=0.2

# Refiner temperature (improvement focus)
# 0.5 balances guided improvement with variety
REFINER_TEMPERATURE=0.5

# ============================================================================
# QUALITY & REFINEMENT SETTINGS
# ============================================================================

# Target evaluation score (0-100) for refinement loop
# Set higher for better quality, lower for faster results
# Default: 80 (recommended)
EVALUATOR_TARGET_SCORE=80

# Maximum refinement iterations (1-10)
# More iterations = better quality but slower + higher cost
# Default: 3 (recommended)
REFINER_MAX_ITERATIONS=3

# Request timeout in seconds for API calls
REQUEST_TIMEOUT_SECONDS=30

# Maximum retry attempts for failed API calls
MAX_RETRIES=3

# ============================================================================
# MEMORY & CACHING SETTINGS
# ============================================================================

# Enable local memory store for learning from past queries
MEMORY_ENABLED=true

# Path to memory store file (local JSON store)
MEMORY_STORE_PATH=memory_store.json

# Maximum number of memories to store
MEMORY_MAX_SIZE=1000

# Cache time-to-live in seconds (1 hour)
CACHE_TTL_SECONDS=3600

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# Number of worker processes (for production)
# Recommendation: 2 * CPU_COUNT + 1
WORKERS=4

# ============================================================================
# RATE LIMITING
# ============================================================================

# Requests per minute limit per client
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
# Use 'json' for production (easier parsing by log aggregators)
LOG_FORMAT=json

# ============================================================================
# PRODUCTION-SPECIFIC SETTINGS
# ============================================================================

# For production deployment:
# ENV=production
# DEBUG=false
# OPENROUTER_MODEL=openai/gpt-4-turbo
# EVALUATOR_TARGET_SCORE=85
# REFINER_MAX_ITERATIONS=5
# LOG_LEVEL=WARNING
# LOG_FORMAT=json
# WORKERS=8

# ============================================================================
# Notes
# ============================================================================

# - API Key: Get one free at https://openrouter.ai
# - Never commit your .env file to version control
# - For production, use a secrets manager
